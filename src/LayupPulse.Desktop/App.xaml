<Application x:Class="LayupPulse.Desktop.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Resources/Colors.xaml" />
        <ResourceDictionary Source="Resources/Spacing.xaml" />
        <ResourceDictionary Source="Resources/Typography.xaml" />
        <ResourceDictionary Source="Resources/Buttons.xaml" />
        <ResourceDictionary Source="Resources/Cards.xaml" />
        <ResourceDictionary Source="Resources/StateBadges.xaml" />
        <ResourceDictionary Source="Resources/DataGrid.xaml" />
        <ResourceDictionary Source="Resources/Navigation.xaml" />
        <ResourceDictionary Source="Resources/Controls.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>
</Application>
