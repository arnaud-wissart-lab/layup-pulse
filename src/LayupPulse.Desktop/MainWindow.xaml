<Window x:Class="LayupPulse.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        xmlns:local="clr-namespace:LayupPulse.Desktop"
        xmlns:views="clr-namespace:LayupPulse.Desktop.Views"
        Title="LayupPulse"
        Width="1280"
        Height="800"
        MinWidth="1000"
        MinHeight="650"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackgroundBrush}"
        Foreground="{StaticResource PrimaryTextBrush}"
        TextOptions.TextFormattingMode="Display"
        automation:AutomationProperties.AutomationId="LayupPulseMainWindow"
        automation:AutomationProperties.Name="Application de supervision simulée LayupPulse">
  <Window.Resources>
    <DataTemplate DataType="{x:Type local:OverviewViewModel}">
      <views:OverviewView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type local:DiagnosticsViewModel}">
      <views:DiagnosticsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type local:AlarmsViewModel}">
      <views:AlarmsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type local:HistoryViewModel}">
      <views:HistoryView />
    </DataTemplate>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="34" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="196" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Row="0"
            Grid.ColumnSpan="2"
            Padding="20,14"
            Background="{StaticResource SidebarBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,0,1">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Margin="0,0,28,0"
                    VerticalAlignment="Center">
          <TextBlock FontSize="21"
                     FontWeight="Bold"
                     Foreground="{StaticResource AccentBrush}"
                     Text="LAYUPPULSE" />
          <TextBlock Foreground="{StaticResource MutedTextBrush}"
                     FontSize="11"
                     Text="CELLULE DE DÉPOSE SIMULÉE" />
        </StackPanel>

        <WrapPanel Grid.Column="1"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center">
          <Border Margin="0,0,10,0"
                  Style="{StaticResource StateBadgeStyle}"
                  Tag="{Binding ConnectionTone}"
                  automation:AutomationProperties.AutomationId="HeaderConnectionBadge"
                  automation:AutomationProperties.Name="{Binding ConnectionStatus}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Margin="0,0,6,0"
                         FontWeight="Bold"
                         Text="{Binding ConnectionGlyph}" />
              <TextBlock FontWeight="SemiBold"
                         Text="{Binding ConnectionStatus}"
                         automation:AutomationProperties.AutomationId="HeaderConnectionText"
                         automation:AutomationProperties.Name="{Binding ConnectionStatus}" />
            </StackPanel>
          </Border>
          <Border Margin="0,0,10,0"
                  Style="{StaticResource StateBadgeStyle}"
                  Tag="{Binding MachineTone}"
                  automation:AutomationProperties.AutomationId="HeaderMachineStateBadge"
                  automation:AutomationProperties.Name="{Binding MachineState}">
            <StackPanel Orientation="Horizontal">
              <TextBlock Margin="0,0,6,0"
                         FontWeight="Bold"
                         Text="{Binding MachineGlyph}" />
              <TextBlock FontWeight="SemiBold"
                         Text="{Binding MachineState}"
                         automation:AutomationProperties.AutomationId="HeaderMachineStateText"
                         automation:AutomationProperties.Name="{Binding MachineState}" />
            </StackPanel>
          </Border>
          <StackPanel Width="170"
                      Margin="4,0,14,0">
            <TextBlock Style="{StaticResource LabelTextStyle}"
                       Text="RECETTE"
                       ToolTip="Ensemble de paramètres fictifs chargé pour exécuter un cycle simulé." />
            <TextBlock Text="{Binding LoadedRecipe}"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding LoadedRecipe}" />
          </StackPanel>
          <StackPanel Width="96"
                      Margin="0,0,14,0">
            <TextBlock Style="{StaticResource LabelTextStyle}" Text="PROGRESSION" />
            <TextBlock FontFamily="{StaticResource NumericFont}"
                       FontWeight="SemiBold"
                       Text="{Binding HeaderProgress}" />
            <ProgressBar Height="4"
                         Margin="0,4,0,0"
                         Maximum="100"
                         Value="{Binding Overview.CycleProgressValue, Mode=OneWay}"
                         Style="{StaticResource IndustrialProgressBarStyle}" />
          </StackPanel>
          <StackPanel Width="105"
                      Margin="0,0,14,0">
            <TextBlock Style="{StaticResource LabelTextStyle}"
                       Text="ÂGE TÉLÉMÉTRIE"
                       ToolTip="Temps écoulé depuis la dernière mesure reçue du simulateur." />
            <TextBlock FontFamily="{StaticResource NumericFont}"
                       FontSize="12"
                       Text="{Binding TelemetryAge}" />
          </StackPanel>
          <StackPanel Width="142">
            <TextBlock Style="{StaticResource LabelTextStyle}" Text="HEURE LOCALE" />
            <TextBlock FontFamily="{StaticResource NumericFont}"
                       FontSize="12"
                       Text="{Binding CurrentLocalTime}" />
          </StackPanel>
        </WrapPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="0"
            Background="{StaticResource SidebarBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,0,1,0">
      <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Bottom"
                Margin="14"
                Padding="10"
                Background="{StaticResource PanelBackgroundBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
          <TextBlock Foreground="{StaticResource MutedTextBrush}"
                     FontSize="10"
                     Text="DÉMONSTRATEUR LOGICIEL&#x0a;Aucun matériel réel"
                     TextWrapping="Wrap" />
        </Border>
        <ListBox Margin="0,16,0,0"
                 ItemsSource="{Binding NavigationItems}"
                 SelectedItem="{Binding SelectedNavigation}"
                 Style="{StaticResource NavigationListStyle}"
                 ItemContainerStyle="{StaticResource NavigationItemStyle}"
                 automation:AutomationProperties.Name="Navigation principale">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="26" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center"
                           FontFamily="{StaticResource NumericFont}"
                           FontWeight="Bold"
                           Text="{Binding Glyph}" />
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Text="{Binding Title}" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <ContentControl Grid.Row="1"
                    Grid.Column="1"
                    Content="{Binding CurrentPage}"
                    Focusable="False" />

    <Border Grid.Row="2"
            Grid.ColumnSpan="2"
            Padding="14,6"
            Background="{StaticResource PanelBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                   Text="{Binding Overview.LastCommandFeedback}"
                   TextTrimming="CharacterEllipsis"
                   ToolTip="{Binding Overview.LastCommandFeedback}" />
        <TextBlock Grid.Column="1"
                   Margin="18,0,0,0"
                   Foreground="{StaticResource MutedTextBrush}"
                   Text="Mode simulation uniquement" />
      </Grid>
    </Border>
  </Grid>
</Window>
