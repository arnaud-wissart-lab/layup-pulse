<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <FontFamily x:Key="InterfaceFont">Segoe UI</FontFamily>
  <FontFamily x:Key="NumericFont">Cascadia Mono, Consolas</FontFamily>

  <Style TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource InterfaceFont}" />
    <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
  </Style>

  <Style x:Key="PageTitleStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="26" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style x:Key="LabelTextStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style x:Key="NumericValueStyle" TargetType="TextBlock">
    <Setter Property="FontFamily" Value="{StaticResource NumericFont}" />
    <Setter Property="FontSize" Value="22" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
</ResourceDictionary>
