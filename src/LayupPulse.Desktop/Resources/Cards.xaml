<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style x:Key="CardStyle" TargetType="Border">
    <Setter Property="Padding" Value="18" />
    <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="{StaticResource CornerMedium}" />
  </Style>

  <Style x:Key="KpiCardStyle"
         BasedOn="{StaticResource CardStyle}"
         TargetType="Border">
    <Setter Property="Margin" Value="0,0,12,12" />
    <Setter Property="MinHeight" Value="104" />
  </Style>

  <Style x:Key="CompactKpiCardStyle" TargetType="Border">
    <Setter Property="Margin" Value="0,0,5,4" />
    <Setter Property="Padding" Value="7,3" />
    <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>
</ResourceDictionary>
