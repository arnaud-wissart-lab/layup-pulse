<UserControl x:Class="LayupPulse.Desktop.Controls.TelemetryChartsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
             Background="{StaticResource PanelBackgroundBrush}"
             automation:AutomationProperties.Name="Tendances télémétriques des soixante dernières secondes">
  <Grid x:Name="ChartsRoot">
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="8" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="8" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    <ContentControl x:Name="TemperatureHost" />
    <ContentControl x:Name="PressureHost" Grid.Column="2" />
    <ContentControl x:Name="ForceHost" Grid.Row="2" />
    <ContentControl x:Name="FeedRateHost" Grid.Row="2" Grid.Column="2" />
  </Grid>
</UserControl>
