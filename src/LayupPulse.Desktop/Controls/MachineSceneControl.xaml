<UserControl x:Class="LayupPulse.Desktop.Controls.MachineSceneControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
             Background="{StaticResource PanelBackgroundBrush}"
             automation:AutomationProperties.Name="Visualisation tridimensionnelle de la cellule fictive">
  <Grid>
    <Grid x:Name="SceneHost" Background="#0B1218" />

    <Border Margin="10"
            Padding="9,6"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="#D915212B"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
      CornerRadius="4">
      <StackPanel>
        <StackPanel Orientation="Horizontal">
          <TextBlock VerticalAlignment="Center"
                     FontSize="11"
                     FontWeight="SemiBold"
                     Text="CELLULE FICTIVE · VUE 3D" />
          <Button x:Name="SceneHelpButton"
                  Width="24"
                  MinHeight="24"
                  Margin="7,0,0,0"
                  Padding="0"
                  VerticalAlignment="Center"
                  automation:AutomationProperties.AutomationId="MachineSceneHelpButton"
                  automation:AutomationProperties.HelpText="Cube bleu : tête de dépose simulée portée par le robot.&#10;Cylindre gris : moule ou mandrin sur lequel la fibre est déposée.&#10;Bandes vertes : passages de fibre considérés comme déjà déposés.&#10;Lignes grises : trajectoires restant à parcourir.&#10;La scène est schématique et ne simule pas la physique réelle du matériau."
                  automation:AutomationProperties.Name="Afficher l’aide de la visualisation 3D"
                  Click="OnSceneHelpClicked"
                  Content="?"
                  LostKeyboardFocus="OnSceneHelpButtonLostKeyboardFocus"
                  Style="{StaticResource SecondaryButtonStyle}">
            <Button.ToolTip>
              <ToolTip x:Name="SceneHelpToolTip"
                       Content="Cube bleu : tête de dépose simulée portée par le robot.&#10;Cylindre gris : moule ou mandrin sur lequel la fibre est déposée.&#10;Bandes vertes : passages de fibre considérés comme déjà déposés.&#10;Lignes grises : trajectoires restant à parcourir.&#10;La scène est schématique et ne simule pas la physique réelle du matériau."
                       Placement="Bottom"
                       automation:AutomationProperties.Name="Légende de la visualisation 3D" />
            </Button.ToolTip>
          </Button>
        </StackPanel>
        <StackPanel Margin="0,5,0,0" Orientation="Horizontal">
          <TextBlock Foreground="#42C891" Text="━ Déposé" />
          <TextBlock Margin="12,0,0,0" Foreground="#6C8797" Text="━ Restant" />
        </StackPanel>
      </StackPanel>
    </Border>

    <StackPanel Margin="10"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Orientation="Horizontal">
      <Button Padding="9,5"
              Click="OnFitViewClicked"
              Content="Ajuster"
              Style="{StaticResource SecondaryButtonStyle}"
              ToolTip="Ajuster la caméra à toute la cellule" />
      <Button Padding="9,5"
              Click="OnResetCameraClicked"
              Content="Réinitialiser la vue"
              Style="{StaticResource SecondaryButtonStyle}"
              ToolTip="Rétablir l’angle de caméra initial" />
    </StackPanel>

    <Border x:Name="StateBanner"
            Margin="10"
            Padding="10,6"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Background="#E63D321A"
            BorderBrush="{StaticResource WarningBrush}"
            BorderThickness="1"
            CornerRadius="4"
            Visibility="Collapsed">
      <TextBlock x:Name="StateBannerText" FontWeight="SemiBold" />
    </Border>
  </Grid>
</UserControl>
