<UserControl x:Class="LayupPulse.Desktop.Views.OverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
             xmlns:controls="clr-namespace:LayupPulse.Desktop.Controls"
             Background="{StaticResource WindowBackgroundBrush}">
  <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
    <Grid MinHeight="620" Margin="16">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="310" />
        <RowDefinition Height="12" />
        <RowDefinition Height="*" MinHeight="250" />
      </Grid.RowDefinitions>

      <Grid Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Style="{StaticResource PageTitleStyle}" Text="Vue d’ensemble" />
          <TextBlock Margin="0,2,0,0"
                     Foreground="{StaticResource SecondaryTextBrush}"
                     Text="Supervision temps réel de la cellule de dépose fictive" />
        </StackPanel>
        <Border Grid.Column="1"
                Padding="10,6"
                VerticalAlignment="Center"
                Style="{StaticResource StateBadgeStyle}"
                Tag="{Binding FeedbackTone}">
          <StackPanel Orientation="Horizontal">
            <TextBlock Margin="0,0,7,0" FontWeight="Bold" Text="{Binding FeedbackGlyph}" />
            <TextBlock MaxWidth="410"
                       Text="{Binding LastCommandFeedback}"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding LastCommandFeedback}" />
          </StackPanel>
        </Border>
      </Grid>

      <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" MinWidth="430" />
          <ColumnDefinition Width="12" />
          <ColumnDefinition Width="342" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
          <controls:MachineSceneControl HeadX="{Binding HeadXMillimeters}"
                                        HeadY="{Binding HeadYMillimeters}"
                                        HeadZ="{Binding HeadZMillimeters}"
                                        MachineState="{Binding MachineStateValue}"
                                        Progress="{Binding CycleProgressValue}" />
        </Border>

        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="12">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Procédé" />
              <TextBlock Grid.Column="1"
                         FontFamily="{StaticResource NumericFont}"
                         FontWeight="SemiBold"
                         Text="{Binding CycleProgress}" />
              <ProgressBar Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Height="6"
                           Margin="0,7,0,0"
                           Maximum="100"
                           Value="{Binding CycleProgressValue, Mode=OneWay}"
                           Style="{StaticResource IndustrialProgressBarStyle}"
                           automation:AutomationProperties.Name="Progression du cycle simulé" />
            </Grid>

            <UniformGrid Grid.Row="1" Margin="0,17,0,8" Columns="2" Rows="3">
              <Border Style="{StaticResource CompactKpiCardStyle}" ToolTip="Débit matière demandé par la recette, en millimètres par seconde">
                <StackPanel>
                  <TextBlock Style="{StaticResource LabelTextStyle}" Text="DÉBIT CIBLE" />
                  <TextBlock Style="{StaticResource CompactNumericValueStyle}" Text="{Binding TargetFeedRate}" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CompactKpiCardStyle}" ToolTip="Débit matière mesuré par le simulateur, en millimètres par seconde">
                <StackPanel>
                  <TextBlock Style="{StaticResource LabelTextStyle}" Text="DÉBIT RÉEL" />
                  <TextBlock Style="{StaticResource CompactNumericValueStyle}" Text="{Binding ActualFeedRate}" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CompactKpiCardStyle}" ToolTip="Force de compactage simulée, en newtons">
                <StackPanel>
                  <TextBlock Style="{StaticResource LabelTextStyle}" Text="COMPACTAGE" />
                  <TextBlock Style="{StaticResource CompactNumericValueStyle}" Text="{Binding CompactionForce}" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CompactKpiCardStyle}" ToolTip="Température du chauffage matière simulé, en degrés Celsius">
                <StackPanel>
                  <TextBlock Style="{StaticResource LabelTextStyle}" Text="TEMPÉRATURE" />
                  <TextBlock Style="{StaticResource CompactNumericValueStyle}" Text="{Binding HeaterTemperature}" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CompactKpiCardStyle}" ToolTip="Pression de l’alimentation matière simulée, en bar">
                <StackPanel>
                  <TextBlock Style="{StaticResource LabelTextStyle}" Text="PRESSION" />
                  <TextBlock Style="{StaticResource CompactNumericValueStyle}" Text="{Binding MaterialPressure}" />
                </StackPanel>
              </Border>
              <Border Style="{StaticResource CompactKpiCardStyle}" ToolTip="Indice synthétique de santé du procédé fictif, en pourcentage">
                <StackPanel>
                  <TextBlock Style="{StaticResource LabelTextStyle}" Text="SANTÉ PROCÉDÉ" />
                  <TextBlock Style="{StaticResource CompactNumericValueStyle}" Text="{Binding ProcessHealth}" />
                </StackPanel>
              </Border>
            </UniformGrid>

            <StackPanel Grid.Row="2">
              <TextBlock Margin="0,0,0,7"
                         Foreground="{StaticResource SecondaryTextBrush}"
                         FontSize="11"
                         Text="{Binding AvailabilityMessage}"
                         TextTrimming="CharacterEllipsis"
                         ToolTip="{Binding AvailabilityMessage}" />
              <UniformGrid Columns="4">
                <Button automation:AutomationProperties.AutomationId="ConnectButton"
                        automation:AutomationProperties.Name="Connecter le simulateur"
                        Command="{Binding ConnectCommand}"
                        Content="Connecter"
                        Style="{StaticResource PrimaryCompactButtonStyle}"
                        ToolTip="{Binding AvailabilityMessage}" />
                <Button automation:AutomationProperties.AutomationId="DisconnectButton"
                        automation:AutomationProperties.Name="Déconnecter le simulateur"
                        Command="{Binding DisconnectCommand}"
                        Content="Déconnecter"
                        Style="{StaticResource CompactButtonStyle}"
                        ToolTip="{Binding AvailabilityMessage}" />
                <Button automation:AutomationProperties.AutomationId="LoadRecipeButton"
                        automation:AutomationProperties.Name="Charger la recette de démonstration"
                        Command="{Binding LoadDemoRecipeCommand}"
                        Content="Recette"
                        Style="{StaticResource CompactButtonStyle}"
                        ToolTip="{Binding AvailabilityMessage}" />
                <Button automation:AutomationProperties.AutomationId="StartButton"
                        automation:AutomationProperties.Name="Démarrer le cycle"
                        Command="{Binding StartCommand}"
                        Content="Démarrer"
                        Style="{StaticResource PrimaryCompactButtonStyle}"
                        ToolTip="{Binding AvailabilityMessage}" />
                <Button automation:AutomationProperties.AutomationId="PauseButton"
                        automation:AutomationProperties.Name="Mettre le cycle en pause"
                        Command="{Binding PauseCommand}"
                        Content="Pause"
                        Style="{StaticResource CompactButtonStyle}"
                        ToolTip="{Binding AvailabilityMessage}" />
                <Button automation:AutomationProperties.AutomationId="ResumeButton"
                        automation:AutomationProperties.Name="Reprendre le cycle"
                        Command="{Binding ResumeCommand}"
                        Content="Reprendre"
                        Style="{StaticResource CompactButtonStyle}"
                        ToolTip="{Binding AvailabilityMessage}" />
                <Button automation:AutomationProperties.AutomationId="StopButton"
                        automation:AutomationProperties.Name="Arrêter le cycle simulé"
                        Command="{Binding StopCommand}"
                        Content="Arrêter"
                        Style="{StaticResource DangerCompactButtonStyle}"
                        ToolTip="{Binding AvailabilityMessage}" />
                <Button automation:AutomationProperties.AutomationId="ResetButton"
                        automation:AutomationProperties.Name="Réinitialiser la machine simulée"
                        Command="{Binding ResetCommand}"
                        Content="Réinitialiser"
                        Style="{StaticResource CompactButtonStyle}"
                        ToolTip="{Binding AvailabilityMessage}" />
              </UniformGrid>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>

      <Grid Grid.Row="3">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="2.25*" MinWidth="500" />
          <ColumnDefinition Width="12" />
          <ColumnDefinition Width="*" MinWidth="230" />
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}" Padding="8">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Margin="5,2,5,6">
              <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Tendances · 60 dernières secondes" />
              <TextBlock HorizontalAlignment="Right"
                         VerticalAlignment="Center"
                         Foreground="{StaticResource MutedTextBrush}"
                         FontSize="11"
                         Text="Actualisation 5 Hz max · 600 points/signal" />
            </Grid>
            <controls:TelemetryChartsControl Grid.Row="1" History="{Binding TelemetryHistory}" />
          </Grid>
        </Border>

        <Grid Grid.Column="2">
          <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
          </Grid.RowDefinitions>
          <Border Style="{StaticResource CardStyle}" Padding="14">
            <StackPanel>
              <TextBlock Style="{StaticResource LabelTextStyle}" Text="ALARMES ACTIVES" />
              <TextBlock Margin="0,8,0,0"
                         FontWeight="SemiBold"
                         Text="{Binding ActiveAlarmSummary}"
                         TextWrapping="Wrap" />
              <TextBlock Margin="0,8,0,0"
                         Foreground="{StaticResource SecondaryTextBrush}"
                         FontSize="11"
                         Text="Les alarmes détaillées et leur acquittement restent disponibles dans la page Alarmes."
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="14">
            <StackPanel>
              <TextBlock Style="{StaticResource LabelTextStyle}" Text="DERNIER DIAGNOSTIC" />
              <TextBlock Margin="0,8,0,0"
                         Text="{Binding LatestDiagnosticStatus}"
                         TextWrapping="Wrap" />
              <Separator Margin="0,10,0,8" Background="{StaticResource BorderBrush}" />
              <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                         FontFamily="{StaticResource NumericFont}"
                         FontSize="11"
                         Text="{Binding LastTelemetryTimestamp, StringFormat=Échantillon : {0}}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </Grid>
      </Grid>
    </Grid>
  </ScrollViewer>
</UserControl>
