<UserControl x:Class="LayupPulse.Desktop.Views.AlarmsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
             Background="{StaticResource WindowBackgroundBrush}">
  <Grid Margin="24,20,24,28">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel>
      <TextBlock Style="{StaticResource PageTitleStyle}" Text="Alarmes" />
      <TextBlock Margin="0,4,0,18"
                 Foreground="{StaticResource SecondaryTextBrush}"
                 Text="Les alarmes actives et levées sont séparées. L’acquittement confirme la prise de connaissance sans lever la condition simulée." />
    </StackPanel>

    <Grid Grid.Row="1" Margin="0,0,0,14">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="220" />
        <ColumnDefinition Width="12" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      <Border Style="{StaticResource KpiCardStyle}">
        <StackPanel>
          <TextBlock Style="{StaticResource LabelTextStyle}" Text="ALARMES ACTIVES" />
          <TextBlock Margin="0,7,0,0"
                     Style="{StaticResource NumericValueStyle}"
                     Text="{Binding ActiveAlarmCount}" />
        </StackPanel>
      </Border>
      <Border Grid.Column="2" Style="{StaticResource CardStyle}">
        <WrapPanel VerticalAlignment="Center">
          <TextBlock Margin="0,7,10,0"
                     Style="{StaticResource LabelTextStyle}"
                     Text="SÉVÉRITÉ"
                     ToolTip="Niveau d’importance attribué à l’alarme simulée." />
          <ComboBox Width="160"
                    Margin="0,0,22,0"
                    ItemsSource="{Binding SeverityFilters}"
                    SelectedItem="{Binding SelectedSeverity}"
                    automation:AutomationProperties.Name="Filtre de sévérité" />
          <CheckBox VerticalAlignment="Center"
                    IsChecked="{Binding ShowHistory}"
                    Content="Afficher l’historique"
                    ToolTip="Inclut les alarmes terminées en plus des alarmes actives."
                    automation:AutomationProperties.Name="Basculer entre les alarmes actives et historiques" />
          <Button Margin="22,0,0,0"
                  Command="{Binding AcknowledgeCommand}"
                  Content="Acquitter la sélection"
                  Style="{StaticResource PrimaryButtonStyle}"
                  ToolTip="Confirme la prise de connaissance sans supprimer la condition simulée."
                  automation:AutomationProperties.Name="Acquitter l’alarme sélectionnée" />
        </WrapPanel>
      </Border>
    </Grid>

    <TextBlock Grid.Row="2"
               Margin="0,0,0,10"
               Style="{StaticResource SectionTitleStyle}"
               Text="{Binding ViewTitle}" />

    <Grid Grid.Row="3">
      <DataGrid ItemsSource="{Binding VisibleAlarms}"
                AutoGenerateColumns="False"
                SelectedItem="{Binding SelectedAlarm}"
                Style="{StaticResource IndustrialDataGridStyle}"
                automation:AutomationProperties.Name="Liste des alarmes">
        <DataGrid.RowStyle>
          <Style TargetType="DataGridRow"
                 BasedOn="{StaticResource IndustrialDataGridRowStyle}">
            <Setter Property="Background" Value="{StaticResource DangerSurfaceBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsAcknowledged}" Value="True">
                <Setter Property="Background" Value="{StaticResource PanelRaisedBrush}" />
                <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
                <Setter Property="FontWeight" Value="Normal" />
              </DataTrigger>
              <DataTrigger Binding="{Binding IsActive}" Value="False">
                <Setter Property="Background" Value="{StaticResource DisabledSurfaceBrush}" />
                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                <Setter Property="FontWeight" Value="Normal" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </DataGrid.RowStyle>
        <DataGrid.Columns>
          <DataGridTextColumn Width="100" Binding="{Binding Severity}" Header="Sévérité" />
          <DataGridTextColumn Width="150" Binding="{Binding Code}" Header="Code" />
          <DataGridTextColumn Width="155" Binding="{Binding Source}" Header="Source" />
          <DataGridTextColumn Width="*" Binding="{Binding Message}" Header="Message" />
          <DataGridTextColumn Width="145" Binding="{Binding Raised}" Header="Levée" />
          <DataGridTextColumn Width="145" Binding="{Binding Acknowledged}" Header="Acquittée" />
          <DataGridTextColumn Width="145" Binding="{Binding Cleared}" Header="Terminée" />
        </DataGrid.Columns>
      </DataGrid>

      <Border Padding="24"
              Background="{StaticResource PanelBackgroundBrush}"
              BorderBrush="{StaticResource BorderBrush}"
              BorderThickness="1">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding HasVisibleAlarms}" Value="True">
                <Setter Property="Visibility" Value="Collapsed" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <TextBlock HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="{StaticResource SecondaryTextBrush}"
                   Text="{Binding EmptyStateMessage}" />
      </Border>
    </Grid>
  </Grid>
</UserControl>
