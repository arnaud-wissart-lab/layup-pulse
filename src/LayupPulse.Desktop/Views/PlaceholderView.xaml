<UserControl x:Class="LayupPulse.Desktop.Views.PlaceholderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource WindowBackgroundBrush}">
  <Grid Margin="24">
    <Border MaxWidth="620"
            Padding="36"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Style="{StaticResource CardStyle}">
      <StackPanel HorizontalAlignment="Center">
        <Border Width="58"
                Height="58"
                Margin="0,0,0,18"
                Background="{StaticResource PanelRaisedBrush}"
                BorderBrush="{StaticResource BorderStrongBrush}"
                BorderThickness="1"
                CornerRadius="29">
          <TextBlock HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontFamily="{StaticResource NumericFont}"
                     FontSize="24"
                     FontWeight="Bold"
                     Foreground="{StaticResource AccentBrush}"
                     Text="{Binding Glyph}" />
        </Border>
        <TextBlock HorizontalAlignment="Center"
                   Style="{StaticResource PageTitleStyle}"
                   Text="{Binding Title}" />
        <TextBlock MaxWidth="480"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Center"
                   Foreground="{StaticResource SecondaryTextBrush}"
                   Text="{Binding Description}"
                   TextAlignment="Center"
                   TextWrapping="Wrap" />
        <TextBlock Margin="0,18,0,0"
                   HorizontalAlignment="Center"
                   Foreground="{StaticResource MutedTextBrush}"
                   FontSize="11"
                   Text="Aucune donnée fictive n’est affichée." />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
