<UserControl x:Class="LayupPulse.Desktop.Views.DiagnosticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
             Background="{StaticResource WindowBackgroundBrush}">
  <ScrollViewer VerticalScrollBarVisibility="Auto"
                HorizontalScrollBarVisibility="Disabled">
    <StackPanel Margin="24,20,24,28">
      <TextBlock Style="{StaticResource PageTitleStyle}" Text="Diagnostics" />
      <TextBlock Margin="0,4,0,18"
                 Foreground="{StaticResource SecondaryTextBrush}"
                 Text="État de la communication, compteurs bornés et messages applicatifs récents." />

      <UniformGrid Columns="3">
        <Border Style="{StaticResource KpiCardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource LabelTextStyle}" Text="POINT D’ACCÈS CONFIGURÉ" />
            <TextBlock Margin="0,7,0,0"
                       FontFamily="{StaticResource NumericFont}"
                       Text="{Binding Endpoint}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>
        <Border Style="{StaticResource KpiCardStyle}"
                Tag="{Binding ConnectionTone}">
          <StackPanel>
            <TextBlock Style="{StaticResource LabelTextStyle}" Text="ÉTAT DE CONNEXION" />
            <TextBlock Margin="0,7,0,0"
                       FontSize="19"
                       FontWeight="SemiBold"
                       Text="{Binding ConnectionStatus}" />
          </StackPanel>
        </Border>
        <Border Style="{StaticResource KpiCardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource LabelTextStyle}" Text="DERNIÈRE COMMUNICATION" />
            <TextBlock Margin="0,7,0,0"
                       FontFamily="{StaticResource NumericFont}"
                       Text="{Binding LastSuccessfulCommunication}"
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,5,0,0"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="{Binding DataAge, StringFormat=Âge : {0}}" />
          </StackPanel>
        </Border>
        <Border Style="{StaticResource KpiCardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource LabelTextStyle}" Text="SÉQUENCE LA PLUS RÉCENTE" />
            <TextBlock Margin="0,7,0,0"
                       Style="{StaticResource NumericValueStyle}"
                       Text="{Binding LatestSequenceNumber}" />
          </StackPanel>
        </Border>
        <Border Style="{StaticResource KpiCardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource LabelTextStyle}" Text="ÉCHANTILLONS REÇUS" />
            <TextBlock Margin="0,7,0,0"
                       Style="{StaticResource NumericValueStyle}"
                       Text="{Binding ReceivedSampleCount}" />
          </StackPanel>
        </Border>
        <Border Style="{StaticResource KpiCardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource LabelTextStyle}" Text="DURÉE DE CONNEXION" />
            <TextBlock Margin="0,7,0,0"
                       Style="{StaticResource NumericValueStyle}"
                       Text="{Binding ConnectionDuration}" />
          </StackPanel>
        </Border>
      </UniformGrid>

      <TextBlock Margin="0,4,0,10"
                 Style="{StaticResource SectionTitleStyle}"
                 Text="Pipeline télémétrique borné" />
      <UniformGrid Columns="3">
        <Border Style="{StaticResource KpiCardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource LabelTextStyle}" Text="REÇUS · COALESCÉS/PERDUS" />
            <TextBlock Margin="0,7,0,0"
                       FontFamily="{StaticResource NumericFont}"
                       Text="{Binding ReceivedSampleCount, StringFormat={}{0} reçus}" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="{StaticResource WarningBrush}"
                       Text="{Binding DroppedOrCoalescedSamples, StringFormat={}{0} coalescés ou perdus}" />
          </StackPanel>
        </Border>
        <Border Style="{StaticResource KpiCardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource LabelTextStyle}" Text="CADENCE D’ACQUISITION" />
            <TextBlock Margin="0,7,0,0"
                       Style="{StaticResource NumericValueStyle}"
                       Text="{Binding AcquisitionRate}" />
          </StackPanel>
        </Border>
        <Border Style="{StaticResource KpiCardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource LabelTextStyle}" Text="CADENCE DE PUBLICATION UI" />
            <TextBlock Margin="0,7,0,0"
                       Style="{StaticResource NumericValueStyle}"
                       Text="{Binding UiPublicationRate}" />
          </StackPanel>
        </Border>
        <Border Style="{StaticResource KpiCardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource LabelTextStyle}" Text="AGRÉGATS D’UNE SECONDE" />
            <TextBlock Margin="0,7,0,0"
                       Style="{StaticResource NumericValueStyle}"
                       Text="{Binding AggregateCount}" />
          </StackPanel>
        </Border>
        <Border Style="{StaticResource KpiCardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource LabelTextStyle}" Text="TENTATIVES DE RECONNEXION" />
            <TextBlock Margin="0,7,0,0"
                       Style="{StaticResource NumericValueStyle}"
                       Text="{Binding ReconnectCount}" />
          </StackPanel>
        </Border>
        <Border Style="{StaticResource KpiCardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource LabelTextStyle}" Text="HISTORIQUE · CAPACITÉ" />
            <TextBlock Margin="0,7,0,0"
                       Style="{StaticResource NumericValueStyle}"
                       Text="{Binding HistoryUtilization}" />
            <TextBlock Margin="0,4,0,0"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="Fenêtre maximale : 60 s" />
          </StackPanel>
        </Border>
      </UniformGrid>

      <Grid Margin="0,2,0,14">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="12" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource LabelTextStyle}" Text="VERSION DE L’APPLICATION" />
            <TextBlock Margin="0,7,0,0"
                       FontFamily="{StaticResource NumericFont}"
                       FontSize="17"
                       Text="{Binding ApplicationVersion}" />
            <TextBlock Margin="0,12,0,0"
                       Style="{StaticResource LabelTextStyle}"
                       Text="VERSION DU SIMULATEUR" />
            <TextBlock Margin="0,7,0,0"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="{Binding SimulatorVersion}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>
        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock Style="{StaticResource LabelTextStyle}" Text="IDENTIFIANT DE SESSION" />
            <TextBlock Margin="0,7,0,0"
                       FontFamily="{StaticResource NumericFont}"
                       Text="{Binding SessionId}"
                       TextWrapping="Wrap" />
            <TextBlock Margin="0,12,0,0"
                       Style="{StaticResource LabelTextStyle}"
                       Text="DERNIÈRE ERREUR DE COMMUNICATION" />
            <TextBlock Margin="0,7,0,0"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       Text="{Binding LatestCommunicationError}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </Grid>

      <Border Margin="0,2,0,14"
              Tag="{Binding SimulationControlTone}">
        <Border.Style>
          <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsDemoMode}" Value="False">
                <Setter Property="Visibility" Value="Collapsed" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <StackPanel>
          <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Simulation Controls" />
          <TextBlock Margin="0,5,0,5"
                     Foreground="{StaticResource WarningBrush}"
                     FontWeight="SemiBold"
                     Text="Défauts simulés uniquement — ces commandes n’agissent sur aucun matériel réel." />
          <TextBlock Margin="0,0,0,12"
                     Foreground="{StaticResource SecondaryTextBrush}"
                     Text="{Binding SimulationControlStatus}" />
          <ItemsControl ItemsSource="{Binding SimulationFaults}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid Margin="0,3">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock VerticalAlignment="Center"
                             FontFamily="{StaticResource NumericFont}"
                             Text="{Binding Name}" />
                  <TextBlock Grid.Column="1"
                             VerticalAlignment="Center"
                             Foreground="{StaticResource SecondaryTextBrush}"
                             Text="{Binding StateText}" />
                  <Button Grid.Column="2"
                          Command="{Binding InjectCommand}"
                          Content="Injecter"
                          Style="{StaticResource DangerButtonStyle}"
                          automation:AutomationProperties.Name="{Binding Name, StringFormat=Injecter le défaut simulé {0}}" />
                  <Button Grid.Column="3"
                          Command="{Binding ClearCommand}"
                          Content="Lever"
                          Style="{StaticResource SecondaryButtonStyle}"
                          automation:AutomationProperties.Name="{Binding Name, StringFormat=Lever le défaut simulé {0}}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <TextBlock Margin="0,2,0,10"
                 Style="{StaticResource SectionTitleStyle}"
                 Text="Messages applicatifs récents" />
      <TextBlock Margin="0,0,0,10"
                 Foreground="{StaticResource SecondaryTextBrush}"
                 Text="La collection est bornée aux 100 événements les plus récents." />
      <DataGrid Height="290"
                ItemsSource="{Binding RecentMessages}"
                Style="{StaticResource IndustrialDataGridStyle}">
        <DataGrid.Columns>
          <DataGridTextColumn Width="110" Binding="{Binding Timestamp}" Header="Heure" />
          <DataGridTextColumn Width="36" Binding="{Binding Glyph}" Header="" />
          <DataGridTextColumn Width="125" Binding="{Binding Level}" Header="Niveau" />
          <DataGridTextColumn Width="*" Binding="{Binding Message}" Header="Message" />
        </DataGrid.Columns>
      </DataGrid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
